{
  "name": "dataverse-powertools",
  "displayName": "Dataverse PowerTools",
  "description": "Tools to help build and manage Dataverse, CDS, Power Platform, PowerApps, and Dynamics 365 CE projects",
  "publisher": "dataversepowertools",
  "icon": "media/logo_new.png",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/pete-mc/dataverse-powertools"
  },
  "version": "0.3.2",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:dataverse-powertools.readProject",
    "onCommand:dataverse-powertools.generateTemplate",
    "workspaceContains:**/dataverse-powertools.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "menus": {
      "explorer/context": [
        {
          "command": "dataverse-powertools.createWebResourceClass",
          "group": "navigation@9",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isWebResource"
        },
        {
          "command": "dataverse-powertools.createWebResourceTest",
          "group": "navigation@10",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isWebResource"
        },
        {
          "command": "dataverse-powertools.createPluginClass",
          "group": "navigation@9",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin"
        },
        {
          "command": "dataverse-powertools.createWorkflowClass",
          "group": "navigation@10",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin"
        },
        {
          "command": "dataverse-powertools.createPluginTest",
          "group": "navigation@11",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && dataverse-powertools.hasPluginUnitTesting"
        }
      ],
      "editor/context": [],
      "view/title": [
        {
          "command": "dataversePowerToolsTableIntersectTree.updateTree",
          "when": "view == dataversePowerToolsTableIntersectTree",
          "group": "navigation"
        },
        {
          "command": "dataversePowerToolsTableIntersectTree.addNewFormIntersect",
          "when": "view == dataversePowerToolsTableIntersectTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dataversePowerToolsTree.addEntry",
          "when": "view == dataversePowerToolsTree && viewItem == Available",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTree.deleteEntry",
          "when": "view == dataversePowerToolsTree && viewItem == Selected",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTree.manualAddToTree",
          "when": "view == dataversePowerToolsTree && viewItem == SelectedRoot",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTree.updateTree",
          "when": "view == dataversePowerToolsTree && viewItem == AvailableRoot",
          "group": "inline"
        },
        {
          "command": "dataverse-powertools.togglePluginEmitEntityEtc",
          "when": "view == dataversePowerToolsTree && viewItem == EmitEntityEtcSetting",
          "group": "inline"
        },
        {
          "command": "dataverse-powertools.editModelBuilderSetting",
          "when": "view == dataversePowerToolsTree && (viewItem == ModelBuilderSetting || viewItem == ModelBuilderFilterItem)",
          "group": "inline"
        },
        {
          "command": "dataverse-powertools.configurePluginEarlyBound",
          "when": "view == dataversePowerToolsTree && viewItem == ModelBuilderConfigureAction",
          "group": "inline"
        },
        {
          "command": "dataverse-powertools.generateEarlyBound",
          "when": "view == dataversePowerToolsTree && viewItem == ModelBuilderGenerateAction",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTableIntersectTree.removeNewFormIntersect",
          "when": "view == dataversePowerToolsTableIntersectTree && viewItem == formintersect",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTableIntersectTree.addForm",
          "when": "view == dataversePowerToolsTableIntersectTree && viewItem == formintersect",
          "group": "inline"
        },
        {
          "command": "dataversePowerToolsTableIntersectTree.removeForm",
          "when": "view == dataversePowerToolsTableIntersectTree && viewItem == form",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dataverse-powertools",
          "title": "Dataverse PowerTools",
          "icon": "media/logo_new.svg"
        }
      ]
    },
    "views": {
      "dataverse-powertools": [
        {
          "id": "dataversePowerToolsMenu",
          "name": "Actions",
          "icon": "media/dep.svg",
          "contextualTitle": "Package Explorer",
          "type": "tree"
        },
        {
          "id": "dataversePowerToolsTree",
          "name": "Earlybound Options",
          "icon": "media/dep.svg",
          "contextualTitle": "Package Explorer",
          "type": "tree",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin"
        },
        {
          "id": "dataversePowerToolsTableIntersectTree",
          "name": "Form Intersects",
          "icon": "media/dep.svg",
          "contextualTitle": "Package Explorer",
          "type": "tree",
          "when": "dataverse-powertools.showLoaded && dataverse-powertools.isWebResource"
        },
        {
          "id": "dataversePowerToolsLocalSettings",
          "name": "Local Settings",
          "icon": "media/dep.svg",
          "contextualTitle": "Local Settings",
          "type": "tree"
        },
        {
          "id": "dataversePowerToolsRequirements",
          "name": "System Requirements",
          "icon": "media/dep.svg",
          "contextualTitle": "System Requirements",
          "type": "tree",
          "visibility": "collapsed"
        }
      ],
      "explorer": []
    },
    "viewsWelcome": [
      {
        "view": "dataversePowerToolsTree",
        "contents": "Plugin early bound settings are not configured.\n[Configure Settings](command:dataverse-powertools.configurePluginEarlyBound)\n[Generate Early Bound](command:dataverse-powertools.generateEarlyBound)",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && dataverse-powertools.isPluginV3 && !dataverse-powertools.hasPluginModelBuilderSettings"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Dataverse PowerTools\nDetecting folder settings...",
        "when": "dataverse-powertools.detectingFolderSettings"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Dataverse PowerTools \n[Initialise Project](command:dataverse-powertools.initialiseProject)",
        "when": "dataverse-powertools.folderStateReady && !dataverse-powertools.showLoaded && !dataverse-powertools.detectingFolderSettings && !dataverse-powertools.hasSupportedProjectType"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Plugin Menu\n[Build Package & Deploy](command:dataverse-powertools.buildAndDeploy)\n[Build Locally](command:dataverse-powertools.buildProject)\n[Run Tests](command:dataverse-powertools.runPluginTests)\n\nTip: Create classes/tests from Explorer right-click menu. Use CodeLens in C# files to add/update class decorations for step registrations.",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && dataverse-powertools.isPluginV3 && dataverse-powertools.hasPluginUnitTesting"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Plugin Menu\n[Build Package & Deploy](command:dataverse-powertools.buildAndDeploy)\n[Build Locally](command:dataverse-powertools.buildProject)\n[Setup Unit Testing](command:dataverse-powertools.setupPluginUnitTesting)\n\nTip: Create classes from Explorer right-click menu. Unit tests can be enabled from the Setup Unit Testing action.",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && dataverse-powertools.isPluginV3 && !dataverse-powertools.hasPluginUnitTesting"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Plugin Menu\n[Build Package & Deploy](command:dataverse-powertools.buildAndDeploy)\n[Build Locally](command:dataverse-powertools.buildProject)\n[Generate Early Bound](command:dataverse-powertools.generateEarlyBound)\n[Run Tests](command:dataverse-powertools.runPluginTests)\n\nTip: Create classes/tests from Explorer right-click menu. Use CodeLens in C# files to add/update class decorations for step registrations.",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && !dataverse-powertools.isPluginV3 && dataverse-powertools.hasPluginUnitTesting"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Plugin Menu\n[Build Package & Deploy](command:dataverse-powertools.buildAndDeploy)\n[Build Locally](command:dataverse-powertools.buildProject)\n[Generate Early Bound](command:dataverse-powertools.generateEarlyBound)\n[Setup Unit Testing](command:dataverse-powertools.setupPluginUnitTesting)\n\nTip: Create classes from Explorer right-click menu. Unit tests can be enabled from the Setup Unit Testing action.",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isPlugin && !dataverse-powertools.isPluginV3 && !dataverse-powertools.hasPluginUnitTesting"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Solution Menu\n[Extract Solution](command:dataverse-powertools.extractSolution)\n[Pack Solution](command:dataverse-powertools.packSolution)\n[Deploy Solution](command:dataverse-powertools.deploySolution)",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isSolution"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Webresource Menu\n[Create New Class](command:dataverse-powertools.createWebResourceClass)\n[Create New Test](command:dataverse-powertools.createWebResourceTest)\n[Build Web Resources](command:dataverse-powertools.buildWebresources)\n[Build & Deploy Web Resources](command:dataverse-powertools.deployWebresources)\n[Generate Typings](command:dataverse-powertools.generateTypings)\n[Add Form Registration](command:dataverse-powertools.addFormDecoration)\n[Register Form Events](command:dataverse-powertools.saveFormData)\n[Upgrade from Spkl](command:dataverse-powertools.upgradeFromSpkl)",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isWebResource && dataverse-powertools.hasSpkl"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "Webresource Menu\n[Create New Class](command:dataverse-powertools.createWebResourceClass)\n[Create New Test](command:dataverse-powertools.createWebResourceTest)\n[Build Web Resources](command:dataverse-powertools.buildWebresources)\n[Build & Deploy Web Resources](command:dataverse-powertools.deployWebresources)\n[Generate Typings](command:dataverse-powertools.generateTypings)\n[Add Form Registration](command:dataverse-powertools.addFormDecoration)\n[Register Form Events](command:dataverse-powertools.saveFormData)",
        "when": "dataverse-powertools.showLoaded && dataverse-powertools.isWebResource && !dataverse-powertools.hasSpkl"
      },
      {
        "view": "dataversePowerToolsLocalSettings",
        "contents": "Local Settings Menu\n[Restore Dependencies](command:dataverse-powertools.restoreDependencies)\n[Update Connection String](command:dataverse-powertools.updateConnectionString)",
        "when": "dataverse-powertools.showLoaded"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "System Requirements\nScanning tools and globals...",
        "when": "dataverse-powertools.requirementsScanning"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "System Requirements",
        "when": "dataverse-powertools.requirementsScanned"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ .NET SDK",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasDotnet"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ .NET SDK — [Download](https://dotnet.microsoft.com/download)",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasDotnet"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ Node.js",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasNode"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ Node.js — [Download](https://nodejs.org/en/download)",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasNode"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ Power Platform CLI (pac)",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasPac"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ Power Platform CLI (pac) — [Download](https://aka.ms/PowerPlatformCLI)",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasPac"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ npm global: jest",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasGlobalJest"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ npm global: jest",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasGlobalJest"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ npm global: webpack",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasGlobalWebpack"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ npm global: webpack",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasGlobalWebpack"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ npm global: webpack-cli",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasGlobalWebpackCli"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ npm global: webpack-cli",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasGlobalWebpackCli"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "✅ npm global: typescript",
        "when": "dataverse-powertools.requirementsScanned && dataverse-powertools.hasGlobalTypescript"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "❌ npm global: typescript",
        "when": "dataverse-powertools.requirementsScanned && !dataverse-powertools.hasGlobalTypescript"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "[Add Missing npm Globals](command:dataverse-powertools.installRequiredGlobals)",
        "when": "dataverse-powertools.requirementsScanned && (!dataverse-powertools.hasGlobalJest || !dataverse-powertools.hasGlobalWebpack || !dataverse-powertools.hasGlobalWebpackCli || !dataverse-powertools.hasGlobalTypescript)"
      },
      {
        "view": "dataversePowerToolsRequirements",
        "contents": "[Recheck Requirements](command:dataverse-powertools.recheckRequirements)",
        "when": "dataverse-powertools.requirementsScanned"
      },
      {
        "view": "dataversePowerToolsMenu",
        "contents": "[Show Log](command:dataverse-powertools.showLog)",
        "when": "true"
      }
    ],
    "commands": [
      {
        "command": "dataversePowerToolsTree.deleteEntry",
        "title": "Remove Table",
        "icon": {
          "light": "media/light/error.svg",
          "dark": "media/dark/error.svg"
        }
      },
      {
        "command": "dataversePowerToolsTree.addEntry",
        "title": "Add Table",
        "icon": {
          "light": "media/light/pass.svg",
          "dark": "media/dark/pass.svg"
        }
      },
      {
        "command": "dataversePowerToolsTree.manualAddToTree",
        "title": "Add Unlisted Earlybound Table",
        "icon": {
          "light": "media/light/add.svg",
          "dark": "media/dark/add.svg"
        }
      },
      {
        "command": "dataversePowerToolsTree.updateTree",
        "title": "Refresh Earlybound Tables From Dataverse",
        "icon": {
          "light": "media/light/refresh.svg",
          "dark": "media/dark/refresh.svg"
        }
      },
      {
        "command": "dataversePowerToolsTableIntersectTree.removeNewFormIntersect",
        "title": "Remove Form Intersect",
        "icon": {
          "light": "media/light/trash.svg",
          "dark": "media/dark/trash.svg"
